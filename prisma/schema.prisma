generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  DEACTIVATE
  REACTIVATE
}

enum EntityType {
  USER
  ACCOUNT
  TRANSACTION
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  name      String    @db.VarChar(100)
  role      UserRole  @default(CUSTOMER)
  hashedRefreshToken String? @db.VarChar(255)
  isActive  Boolean   @default(true)
  deactivatedAt      DateTime?
  deactivationReason String?   @db.VarChar(500)
  reactivatedAt      DateTime?
  reactivationReason String?   @db.VarChar(500)
  accounts  Account[]
  auditLogs AuditLog[] // Relation ke AuditLog
  createdAt DateTime  @default(now())

  @@map("users")
  @@index([email])
  @@index([isActive])
}

model Account {
  id            Int      @id @default(autoincrement())
  accountNumber String   @unique @db.VarChar(20)
  userId        Int
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTrans     Transaction[] @relation("Source")
  receivedTrans Transaction[] @relation("Destination")

  @@map("accounts")
  @@index([userId])
  @@index([accountNumber])
  @@index([isActive])
}

model Transaction {
  id            Int             @id @default(autoincrement())
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  sourceId      Int?
  source        Account?        @relation("Source", fields: [sourceId], references: [id])
  destinationId Int?
  destination   Account?        @relation("Destination", fields: [destinationId], references: [id])
  createdAt     DateTime        @default(now())
  idempotencyKey String?        @unique @db.VarChar(100)

  @@map("transactions")
  @@index([createdAt])
  @@index([sourceId])
  @@index([destinationId])
  @@index([type, createdAt])
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  action      AuditAction
  entityType  EntityType
  entityId    Int?
  adminId     Int? 
  adminEmail  String      @db.VarChar(255)
  oldData     Json?
  newData     Json?
  ipAddress   String?     @db.VarChar(45) 
  userAgent   String?     @db.Text
  createdAt   DateTime    @default(now())

  admin       User?       @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
  @@index([entityType, entityId])
  @@index([adminId])
  @@index([createdAt])
  @@index([action, createdAt])
}
